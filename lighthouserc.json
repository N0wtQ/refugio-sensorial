{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:4173/refugio-sensorial/",
        "http://localhost:4173/refugio-sensorial/kit",
        "http://localhost:4173/refugio-sensorial/mapa",
        "http://localhost:4173/refugio-sensorial/biblioteca",
        "http://localhost:4173/refugio-sensorial/ayuda"
      ],
      "startServerCommand": "npm run preview",
      "startServerReadyPattern": "Local",
      "numberOfRuns": 2
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.92 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
